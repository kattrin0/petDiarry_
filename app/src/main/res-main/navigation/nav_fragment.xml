<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_fragment"
    app:startDestination="@id/authChoiceFragment">

    <fragment
        android:id="@+id/authChoiceFragment"
        android:name="com.example.petDiary.ui.fragments.AuthChoiceFragment"
        android:label="Вход"
        tools:layout="@layout/auth_choice_fragment">

        <action
            android:id="@+id/action_authChoiceFragment_to_loginFragment"
            app:destination="@id/loginFragment" />

    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.petDiary.ui.fragments.LoginFragment"
        android:label="Вход"
        tools:layout="@layout/login_fragment" />

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.example.petDiary.ui.fragments.CalendarFragment"
        android:label="Календарь"
        tools:layout="@layout/fragment_calendar" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.petDiary.ui.fragments.MapFragment"
        android:label="Карта"
        tools:layout="@layout/fragment_map" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.petDiary.ui.fragments.HomeFragment"
        android:label="Главная"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.petDiary.ui.fragments.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" />

</navigation>